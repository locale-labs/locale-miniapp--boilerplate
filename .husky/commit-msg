export PATH="$HOME/.bun/bin:$PATH"

# Valida Conventional Commits. semantic-release (preset angular) solo bumpea
# versión si el commit tiene un tipo válido — un mensaje mal formado pasa
# silencioso y NO deploya prod. Este hook lo corta acá, en local.
#
# Tipos que reconoce semantic-release (ver .releaserc.json):
#   feat fix perf revert refactor build ci chore docs style test
# Solo feat/fix/perf/revert/refactor/build/ci/chore/docs/style/test bumpean;
# cualquier otro prefijo (ej "improve:", "add ...", ".") = NO release.

msg_file="$1"
header=$(head -n1 "$msg_file")

# Dejar pasar merges, reverts de git, y commits fixup/squash de rebase.
case "$header" in
  "Merge "* | "Revert "* | "fixup! "* | "squash! "*) exit 0 ;;
esac

pattern='^(feat|fix|perf|revert|refactor|build|ci|chore|docs|style|test)(\([a-z0-9 ._/-]+\))?!?: .+'

if printf '%s' "$header" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
✖ Commit message inválido — no sigue Conventional Commits.

  El header tiene que empezar con un tipo válido seguido de ": ":

    feat: agrega búsqueda de items
    fix: corrige RLS en items
    fix(api): valida deploy secret
    feat!: cambia el schema (breaking change)

  Tipos válidos: feat fix perf revert refactor build ci chore docs style test
  (feat = minor, fix/perf = patch, feat! / BREAKING CHANGE = major)

  ⚠ Un prefijo no reconocido (ej "improve:", "add ...", ".") NO dispara
    semantic-release → no se bumpea versión → el deploy a prod se SALTEA
    aunque la action quede en verde.

  Bypass de emergencia (no recomendado):  git commit --no-verify
EOF
exit 1
