# MiniApp Supabase (prod instance)
MINIAPP_SUPABASE_URL=
MINIAPP_SUPABASE_ANON_PUBLIC=
MINIAPP_SUPABASE_PROJECT_ID=

# Secret used by the developer/CI to authorize version registration during deployment.
# TECH DEBT: See @NOTES/tech_debt_deploy_secret.md
MINIAPP_DEPLOY_SECRET=

# saved on the supabase miniapp edge functions, used to execute the deploy script from mini-app
MINIAPP_API_KEY=

# Supabase CLI access token (allows deploying edge functions without switching accounts)
# Generate at: Supabase Dashboard > Account > Access Tokens
MINIAPP_SUPABASE_ACCESS_TOKEN=