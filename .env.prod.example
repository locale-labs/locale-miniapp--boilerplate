# MiniApp Supabase (prod instance)
MINIAPP_SUPABASE_URL=
MINIAPP_SUPABASE_ANON_PUBLIC=
MINIAPP_SUPABASE_PROJECT_ID=

# Secret used by the developer/CI to authorize version registration during deployment.
# TECH DEBT: See @NOTES/tech_debt_deploy_secret.md
MINIAPP_DEPLOY_SECRET=

# Deploy token de ESTE miniapp (no es del core, no es global). Generalo con `openssl rand -hex 32`.
# Una vez aca no hace falta nada mas: `make deploy-supabase-functions-dev/prod` lo setea solo como
# secret del edge function `deploy_miniapp` de este miniapp (`supabase secrets set`). En cada deploy el
# builder lo manda en el header `x-miniapp-api-key` y `deploy_miniapp` valida que coincida con su secret.
MINIAPP_API_KEY=

# Supabase CLI access token (allows deploying edge functions without switching Supabase accounts, 1 for each Supabase org)
# Generate at: Supabase Dashboard > Account > Account preferences > Access Tokens -- Create with name "deploy"
MINIAPP_SUPABASE_ACCESS_TOKEN=